{
  "name": "@ivanamato/whatsapp-inbox",
  "version": "0.26.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivanamato/whatsapp-frontend"
  },
  "type": "module",
  "main": "./dist/whatsapp-inbox.umd.js",
  "module": "./dist/whatsapp-inbox.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/whatsapp-inbox.es.js",
      "require": "./dist/whatsapp-inbox.umd.js"
    },
    "./style.css": "./dist/whatsapp-inbox.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "mock-server": "node --experimental-vm-modules --loader ts-node/esm mock-server/index.ts",
    "mock-server:start": "tsx mock-server/index.ts",
    "docker:up": "docker compose up",
    "docker:build": "docker compose build --no-cache",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-virtual": "^3.13.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.545.0",
    "preact": "^10.28.4",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.3.1"
  },
  "overrides": {
    "minimatch": ">=10.2.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@hono/node-server": "^1.19.11",
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "hono": "^4.12.5",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "serve": "^14.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite": "^6",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
